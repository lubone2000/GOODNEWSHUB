rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: stories
    // Fields:
    //   - id: string (required)
    //   - title: string (required)
    //   - summary: string
    //   - category: string
    //   - region: string
    //   - verified_score: number
    //   - status: string (pending, verified, published)
    //   - is_saved: bool
    //   - uid: string (required, owner)
    //   - created_at: timestamp
    //
    // Collection: webhooks
    // Fields:
    //   - name: string (required)
    //   - url: string (required)
    //   - active: bool
    //   - uid: string (required, owner)
    //   - created_at: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "lubone1978@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // Domain Validators
    function isValidStory(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.uid == request.auth.uid;
    }

    function isValidWebhook(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.url is string && isValidUrl(data.url) &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    match /stories/{storyId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidStory(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidStory(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();

      match /sources/{sourceId} {
        allow read, write: if isDocOwner() || isAdmin();
      }
      match /claims/{claimId} {
        allow read, write: if isDocOwner() || isAdmin();
      }
      match /packages/{packageId} {
        allow read, write: if isDocOwner() || isAdmin();
      }
    }

    match /webhooks/{webhookId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidWebhook(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidWebhook(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
